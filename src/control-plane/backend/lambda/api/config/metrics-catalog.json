    {
      "id": "event_name_distribution",
      "name": "Event Name Distribution",
      "nameZh": "事件名分布",
      "category": "event",
      "description": "Event count and value grouped by event name",
      "descriptionZh": "按事件名聚合的触发次数和事件价值",
      "formula": "COUNT(event_id), SUM(event_value) GROUP BY event_name",
      "sourceJob": "EventNameJob",
      "sourceTable": "event_name",
      "sourceFields": [
        "event_id",
        "event_name",
        "event_value",
        "event_timestamp",
        "user_pseudo_id"
