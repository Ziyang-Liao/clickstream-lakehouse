    {
      "id": "dau",
      "name": "DAU",
      "nameZh": "日活跃用户数",
      "category": "user_scale",
      "description": "Number of unique users active on a given day",
      "descriptionZh": "当日去重活跃用户数",
      "formula": "COUNT(DISTINCT user_pseudo_id) WHERE DATE(event_timestamp) = target_date",
      "sourceJob": "ActiveUserJob",
      "sourceTable": "dau",
      "sourceFields": [
        "event_timestamp",
        "user_pseudo_id",
        "platform",
        "app_id"
      ],
      "outputField": "dau",
      "schedule": "cron(0 2 * * ? *)",
      "redshiftView": "clickstream_retention_dau_wau_sp",
      "reportSheet": "Retention Dashboard",
      "modelingPath": "s3tables",
      "computeEngine": "EMR Serverless (Spark)",
      "storageFormat": "S3 Tables (Apache Iceberg)",
      "redshiftModelingPath": {
        "computeEngine": "Redshift Serverless",
        "storageFormat": "Redshift Materialized View",
        "storedProcedure": "clickstream_retention_dau_wau_sp",
        "sourceView": "clickstream_event_base_view (from event_v2 + session + user_v2)"
      }
    },
    {
