    {
      "id": "sessions_per_user",
      "name": "Sessions per User",
      "nameZh": "人均参与会话数",
      "category": "engagement",
      "description": "Average number of engaged sessions per user",
      "descriptionZh": "每个用户的平均参与会话数",
      "formula": "COUNT(engaged_sessions) / COUNT(DISTINCT user_pseudo_id)",
      "sourceJob": "EngagementKpiJob",
      "sourceTable": "engagement_kpi",
      "sourceFields": [
        "session_id",
        "user_pseudo_id",
        "event_name",
        "event_timestamp"
