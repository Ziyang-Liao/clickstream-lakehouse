        "sourceView": "clickstream_event_base_view (from event_v2 + session + user_v2)"
      }
    },
    {
      "id": "engagement_time_per_user",
      "name": "Engagement Time per User",
      "nameZh": "人均参与时长",
      "category": "engagement",
      "description": "Average engagement time per user in seconds",
      "descriptionZh": "每个用户的平均参与时长（秒）",
      "formula": "SUM(user_engagement_time_msec) / 1000 / COUNT(DISTINCT user_pseudo_id)",
      "sourceJob": "EngagementKpiJob",
      "sourceTable": "engagement_kpi",
      "sourceFields": [
        "user_engagement_time_msec",
        "user_pseudo_id",
        "event_timestamp"
      ],
      "outputField": "avg_engagement_time_per_user_seconds",
      "schedule": "cron(0 2 * * ? *)",
