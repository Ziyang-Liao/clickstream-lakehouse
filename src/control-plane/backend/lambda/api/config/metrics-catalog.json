        "storedProcedure": "clickstream_acquisition_country_new_user_sp",
        "sourceView": "clickstream_event_base_view (from event_v2 + session + user_v2)"
      }
    },
    {
      "id": "return_users",
      "name": "Returning Users",
      "nameZh": "回访用户数",
      "category": "user_scale",
      "description": "Number of users who are not first-time visitors",
      "descriptionZh": "非首次访问的去重用户数",
      "formula": "COUNT(DISTINCT user_pseudo_id) WHERE is_new = false",
      "sourceJob": "NewReturnUserJob",
      "sourceTable": "new_return_user",
      "sourceFields": [
        "event_name",
        "user_pseudo_id",
        "first_touch_time_msec",
        "event_timestamp"
      ],
      "outputField": "user_count WHERE user_type = 'return'",
