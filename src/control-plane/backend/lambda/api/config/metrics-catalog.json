    {
      "id": "entrance_pages",
      "name": "Entrance Pages",
      "nameZh": "入口页",
      "category": "page",
      "description": "Top pages where users start their sessions",
      "descriptionZh": "用户开始会话时最常访问的页面",
      "formula": "COUNT(entrance) GROUP BY page_url_path WHERE page_view_entrances = true",
      "sourceJob": "EntranceExitJob",
