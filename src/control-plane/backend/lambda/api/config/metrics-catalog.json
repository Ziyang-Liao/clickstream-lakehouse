    {
      "id": "page_views",
      "name": "Page Views",
      "nameZh": "页面浏览量",
      "category": "page",
      "description": "Number of page/screen views grouped by page path or screen name",
      "descriptionZh": "按页面路径或屏幕名聚合的浏览次数",
      "formula": "COUNT(event_id) WHERE event_name IN ('_page_view', '_screen_view') GROUP BY page_url_path",
      "sourceJob": "PageScreenViewJob",
      "sourceTable": "page_screen_view",
      "sourceFields": [
