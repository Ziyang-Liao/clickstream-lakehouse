    {
      "id": "daily_retention",
      "name": "Daily Retention Rate",
      "nameZh": "日留存率",
      "category": "retention",
      "description": "Percentage of users who return on day N after their first visit",
      "descriptionZh": "用户首次访问后第 N 日回访的比例",
      "formula": "COUNT(DISTINCT retained_users_day_N) / COUNT(DISTINCT cohort_users)",
      "sourceJob": "RetentionAnalysisJob",
      "sourceTable": "retention_daily",
      "sourceFields": [
        "event_timestamp",
        "user_pseudo_id",
        "first_touch_time_msec",
        "platform",
        "app_id"
      ],
      "outputField": "retention_rate",
      "schedule": "cron(0 2 * * ? *)",
