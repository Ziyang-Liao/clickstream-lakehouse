        "sourceView": "clickstream_event_base_view (from event_v2 + session + user_v2)"
      }
    },
    {
      "id": "bounce_rate",
      "name": "Bounce Rate",
      "nameZh": "跳出率",
      "category": "engagement",
      "description": "Percentage of sessions with only one page/screen view",
      "descriptionZh": "仅浏览一个页面/屏幕的会话占比",
      "formula": "COUNT(sessions WHERE view_count <= 1) / COUNT(total_sessions)",
      "sourceJob": "SessionAnalysisJob",
