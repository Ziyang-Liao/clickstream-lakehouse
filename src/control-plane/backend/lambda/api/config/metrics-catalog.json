    {
      "id": "new_users",
      "name": "New Users",
      "nameZh": "新用户数",
      "category": "user_scale",
      "description": "Number of users who triggered _first_open event",
      "descriptionZh": "触发 _first_open 事件的去重用户数",
      "formula": "COUNT(DISTINCT user_pseudo_id) WHERE event_name = '_first_open'",
      "sourceJob": "NewReturnUserJob",
      "sourceTable": "new_return_user",
      "sourceFields": [
        "event_name",
        "user_pseudo_id",
        "first_touch_time_msec",
        "event_timestamp"
      ],
      "outputField": "user_count WHERE user_type = 'new'",
      "schedule": "cron(0 2 * * ? *)",
      "redshiftView": "clickstream_acquisition_country_new_user_sp",
