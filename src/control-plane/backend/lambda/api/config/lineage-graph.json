  "fieldLineage": {
    "event_v2.event_timestamp": {
      "upstream": [{"table": "sdk_raw", "field": "event_timestamp", "transform": "TransformerV3"}],
      "downstream": [
        {"table": "dau", "field": "event_date", "transform": "ActiveUserJob", "logic": "DATE(event_timestamp)"},
        {"table": "retention_daily", "field": "cohort_date", "transform": "RetentionAnalysisJob"},
        {"table": "event_daily_summary", "field": "event_date", "transform": "EventAggregationJob"},
        {"table": "event_daily_summary", "field": "event_hour", "transform": "EventAggregationJob", "logic": "HOUR(event_timestamp)"},
        {"table": "lifecycle_weekly", "field": "time_period_week", "transform": "LifecycleJob", "logic": "WEEK(event_timestamp)"},
        {"table": "session_analysis", "field": "session_start_time", "transform": "SessionAnalysisJob"}
      ]
    },
    "event_v2.user_pseudo_id": {
      "upstream": [{"table": "sdk_raw", "field": "user_pseudo_id", "transform": "TransformerV3"}],
      "downstream": [
        {"table": "dau", "field": "dau", "transform": "ActiveUserJob", "logic": "COUNT(DISTINCT user_pseudo_id)"},
        {"table": "new_return_user", "field": "user_type", "transform": "NewReturnUserJob"},
        {"table": "retention_daily", "field": "retained_users", "transform": "RetentionAnalysisJob"},
        {"table": "user_behavior", "field": "total_events", "transform": "UserBehaviorJob"},
        {"table": "geo_user", "field": "user_count", "transform": "GeoUserJob"},
        {"table": "engagement_kpi", "field": "total_users", "transform": "EngagementKpiJob"},
        {"table": "user_acquisition", "field": "new_user_count", "transform": "UserAcquisitionJob"}
      ]
    },
    "event_v2.event_name": {
      "upstream": [{"table": "sdk_raw", "field": "event_name", "transform": "TransformerV3"}],
      "downstream": [
        {"table": "event_name", "field": "event_count", "transform": "EventNameJob", "logic": "GROUP BY event_name"},
        {"table": "crash_rate", "field": "crash_rate", "transform": "CrashRateJob", "logic": "FILTER event_name='_app_exception'"},
        {"table": "new_return_user", "field": "is_new", "transform": "NewReturnUserJob", "logic": "FILTER event_name='_first_open'"},
        {"table": "lifecycle_weekly", "field": "user_count", "transform": "LifecycleJob", "logic": "FILTER event_name='_session_start'"},
        {"table": "page_screen_view", "field": "view_count", "transform": "PageScreenViewJob", "logic": "FILTER event_name IN ('_page_view','_screen_view')"},
        {"table": "entrance", "field": "entrance_count", "transform": "EntranceExitJob", "logic": "FILTER event_name IN ('_page_view','_screen_view')"}
      ]
    },
    "event_v2.session_id": {
      "upstream": [{"table": "sdk_raw", "field": "session_id", "transform": "TransformerV3"}],
      "downstream": [
        {"table": "session_analysis", "field": "session_duration", "transform": "SessionAnalysisJob"},
        {"table": "engagement_kpi", "field": "engaged_sessions", "transform": "EngagementKpiJob"},
        {"table": "user_acquisition", "field": "session_count", "transform": "UserAcquisitionJob"},
        {"table": "user_behavior", "field": "total_sessions", "transform": "UserBehaviorJob"}
      ]
    },
    "event_v2.device_mobile_model_name": {
      "upstream": [{"table": "sdk_raw", "field": "device_info", "transform": "TransformerV3"}],
      "downstream": [
        {"table": "device", "field": "device_mobile_model_name", "transform": "DeviceJob", "logic": "GROUP BY device_mobile_model_name"}
      ]
    },
    "event_v2.device_ua_browser": {
      "upstream": [{"table": "sdk_raw", "field": "user_agent", "transform": "UAEnrichmentV2", "logic": "Parse User-Agent string"}],
      "downstream": [
        {"table": "device", "field": "device_ua_browser", "transform": "DeviceJob"}
      ]
    },
    "event_v2.geo_country": {
      "upstream": [{"table": "sdk_raw", "field": "ip_address", "transform": "IPEnrichmentV2", "logic": "GeoIP lookup"}],
      "downstream": [
        {"table": "geo_user", "field": "geo_country", "transform": "GeoUserJob", "logic": "GROUP BY geo_country"},
        {"table": "event_daily_summary", "field": "geo_country", "transform": "EventAggregationJob"}
      ]
    },
    "event_v2.geo_city": {
      "upstream": [{"table": "sdk_raw", "field": "ip_address", "transform": "IPEnrichmentV2", "logic": "GeoIP lookup"}],
      "downstream": [
        {"table": "geo_user", "field": "geo_city", "transform": "GeoUserJob", "logic": "GROUP BY geo_city"}
      ]
    },
    "event_v2.traffic_source_source": {
      "upstream": [{"table": "sdk_raw", "field": "utm_source", "transform": "TransformerV3"}],
      "downstream": [
        {"table": "user_acquisition", "field": "traffic_source_source", "transform": "UserAcquisitionJob", "logic": "GROUP BY traffic_source_source"}
      ]
    },
    "event_v2.page_view_page_url_path": {
      "upstream": [{"table": "sdk_raw", "field": "page_url", "transform": "TransformerV3", "logic": "Extract URL path"}],
      "downstream": [
        {"table": "page_screen_view", "field": "page_view_page_url_path", "transform": "PageScreenViewJob"},
        {"table": "entrance", "field": "page_view_page_url_path", "transform": "EntranceExitJob"},
        {"table": "exit", "field": "page_view_page_url_path", "transform": "EntranceExitJob"}
      ]
    },
    "event_v2.user_engagement_time_msec": {
      "upstream": [{"table": "sdk_raw", "field": "engagement_time_msec", "transform": "TransformerV3"}],
      "downstream": [
        {"table": "engagement_kpi", "field": "avg_engagement_time_per_session_seconds", "transform": "EngagementKpiJob", "logic": "SUM / COUNT / 1000"},
        {"table": "session_analysis", "field": "session_duration", "transform": "SessionAnalysisJob"},
        {"table": "user_acquisition", "field": "total_engagement_time_msec", "transform": "UserAcquisitionJob"}
      ]
    },
    "event_v2.event_value": {
      "upstream": [{"table": "sdk_raw", "field": "event_value", "transform": "TransformerV3"}],
      "downstream": [
        {"table": "event_name", "field": "event_value", "transform": "EventNameJob", "logic": "SUM(event_value)"},
        {"table": "user_behavior", "field": "ltv", "transform": "UserBehaviorJob", "logic": "SUM(event_value) per user"}
      ]
    },
    "event_v2.first_touch_time_msec": {
      "upstream": [{"table": "sdk_raw", "field": "first_touch_time_msec", "transform": "TransformerV3"}],
      "downstream": [
        {"table": "new_return_user", "field": "first_date", "transform": "NewReturnUserJob"},
        {"table": "retention_daily", "field": "cohort_date", "transform": "RetentionAnalysisJob", "logic": "DATE(first_touch_time_msec)"}
      ]
    }
  },
