        }
      ],
      "downstream": [
        {
          "table": "geo_user",
          "field": "geo_city",
          "transform": "GeoUserJob",
          "logic": "GROUP BY geo_city"
        }
      ]
    },
    "event_v2.traffic_source_source": {
      "upstream": [
        {
          "table": "sdk_raw",
          "field": "utm_source",
