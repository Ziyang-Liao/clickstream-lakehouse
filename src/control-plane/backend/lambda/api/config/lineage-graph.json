          "table": "sdk_raw",
          "field": "event_value",
          "transform": "TransformerV3"
        }
      ],
      "downstream": [
        {
          "table": "event_name",
          "field": "event_value",
          "transform": "EventNameJob",
          "logic": "SUM(event_value)"
        },
        {
          "table": "user_behavior",
          "field": "ltv",
          "transform": "UserBehaviorJob",
          "logic": "SUM(event_value) per user"
        }
      ]
    },
    "event_v2.first_touch_time_msec": {
      "upstream": [
        {
          "table": "sdk_raw",
          "field": "first_touch_time_msec",
          "transform": "TransformerV3"
        }
      ],
      "downstream": [
        {
          "table": "new_return_user",
          "field": "first_date",
          "transform": "NewReturnUserJob"
        },
        {
          "table": "retention_daily",
          "field": "cohort_date",
          "transform": "RetentionAnalysisJob",
          "logic": "DATE(first_touch_time_msec)"
        }
      ]
    }
