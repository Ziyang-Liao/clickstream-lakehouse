    "event_v2.event_name": {
      "upstream": [
        {
          "table": "sdk_raw",
          "field": "event_name",
          "transform": "TransformerV3"
        }
      ],
      "downstream": [
        {
          "table": "event_name",
          "field": "event_count",
          "transform": "EventNameJob",
          "logic": "GROUP BY event_name"
        },
        {
          "table": "crash_rate",
          "field": "crash_rate",
          "transform": "CrashRateJob",
          "logic": "FILTER event_name='_app_exception'"
        },
        {
          "table": "new_return_user",
          "field": "is_new",
          "transform": "NewReturnUserJob",
          "logic": "FILTER event_name='_first_open'"
        },
        {
          "table": "lifecycle_weekly",
          "field": "user_count",
          "transform": "LifecycleJob",
          "logic": "FILTER event_name='_session_start'"
        },
        {
          "table": "page_screen_view",
          "field": "view_count",
          "transform": "PageScreenViewJob",
          "logic": "FILTER event_name IN ('_page_view','_screen_view')"
        },
        {
          "table": "entrance",
          "field": "entrance_count",
          "transform": "EntranceExitJob",
          "logic": "FILTER event_name IN ('_page_view','_screen_view')"
        }
      ]
    },
    "event_v2.session_id": {
      "upstream": [
        {
          "table": "sdk_raw",
          "field": "session_id",
          "transform": "TransformerV3"
        }
      ],
      "downstream": [
        {
          "table": "session_analysis",
          "field": "session_duration",
          "transform": "SessionAnalysisJob"
        },
        {
          "table": "engagement_kpi",
          "field": "engaged_sessions",
          "transform": "EngagementKpiJob"
        },
        {
          "table": "user_acquisition",
          "field": "session_count",
          "transform": "UserAcquisitionJob"
        },
        {
          "table": "user_behavior",
          "field": "total_sessions",
          "transform": "UserBehaviorJob"
        }
      ]
    },
    "event_v2.device_mobile_model_name": {
      "upstream": [
        {
          "table": "sdk_raw",
          "field": "device_info",
          "transform": "TransformerV3"
        }
      ],
      "downstream": [
        {
          "table": "device",
          "field": "device_mobile_model_name",
          "transform": "DeviceJob",
          "logic": "GROUP BY device_mobile_model_name"
        }
      ]
    },
    "event_v2.device_ua_browser": {
      "upstream": [
        {
          "table": "sdk_raw",
          "field": "user_agent",
          "transform": "UAEnrichmentV2",
          "logic": "Parse User-Agent string"
        }
      ],
      "downstream": [
        {
          "table": "device",
